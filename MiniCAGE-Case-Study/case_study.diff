+        self.ident = ident
+        self.host = host
+        self.username = username
+        self.agent = agent
+        self.timeout = timeout
+        self.pid = pid
+        self.parent = parent
+        self.session_type = SessionType.parse_string(session_type) if type(session_type) is str else session_type
+        self.active = active
+        self.children = {}
+        self.name = name
+        self.is_escalate_sandbox = is_escalate_sandbox
