+    def add_session_info(self,
+                         hostid: str = None,
+                         username: str = None,
+                         session_id: int = None,
+                         agent: str = None,
+                         timeout: int = None,
+                         pid: int = None,
+                         session_type: str = None,
+                         **kwargs):
+        if hostid is None:
