+                user = host.add_user(username=self.username, password=self.password)
+                if user is not None:
+                    obs.set_success(True)
+
+                else:
+                    obs.set_success(False)
+
+            else:
+                obs.set_success(False)
+        else:
+            obs.set_success(False)
+        return obs
