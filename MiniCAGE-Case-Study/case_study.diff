+def get_table(rows):    
+    table = PrettyTable([    
+        'Subnet',    
+        'IP Address',    
+        'Hostname',    
+        'Known',
+        'Scanned',    
+        'Access',    
+        ])    
+    for r in rows:
+        table.add_row(rows[r])
+
+    table.sortby = 'Hostname'
+    return table    
