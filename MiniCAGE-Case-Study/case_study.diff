+                table.add_row([subnet] + [connected])
+            print(f"\n{table}\n")
+            print("-" * 80 + "\n")
+        elif k == "Hosts":
+            print("\n{}\nHosts:\n".format("-"*80))
+            for name, vals in v.items():
+                print(f"Name: {name}")
+                for prop, prop_val in vals.items():
+                    print(f"\t{prop}: {prop_val}")
+                print("\n")
+            print("-"*80 + "\n")
+            continue
+        elif k == "Name":
+            print(v)
+        elif k == "OSINT":
+            print("OSINT: ")
+            print(v)
+        elif k == "Flags":
+            print(f"Number of flags: {v}")
+        else:
+            for name, vals in v.items():
