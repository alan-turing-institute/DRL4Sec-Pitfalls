+            'SSHLoginExploit':{'agent':'Red', 'session':0, 'ip_address': IPv4Address('10.0.0.2'), 'port':22},
+            'SambaUsermapScript': {'agent': 'Red', 'session': 0, 'ip_address': IPv4Address('10.0.0.2')},
+            # 'Schtasks':{'agent':'Red', 'session':1},
