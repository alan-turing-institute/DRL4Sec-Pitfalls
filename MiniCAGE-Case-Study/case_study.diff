+        return {"username": self.username, "session_id": self.ident, "timeout": self.timeout,
+                "pid": self.pid, "session_type": self.session_type, "agent": self.agent}
+
+    def set_orphan(self):
+        self.active = False
+        self.parent = None
+
+    def dead_child(self, child_id: int):
+        self.children.pop(child_id)
+
